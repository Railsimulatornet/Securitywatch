# Copyright Roman Glos 2026
#
# UGREEN SecurityWatch - .env.example
# Deutsche und englische Beschreibung in einer Datei.
# German and English descriptions in one file.
#
# WICHTIG / IMPORTANT
# Diese Datei ist nur eine Vorlage. Kopiere sie vor dem ersten Start zu .env.
# Trage in der echten .env deine eigenen SMTP-Daten ein.
# This file is only a template. Copy it to .env before the first start.
# Enter your own SMTP settings in the real .env file.
#
# Beispiel / Example:
# cp .env.example .env

# ============================================================
# Sprache / Language
# ============================================================

# OUTPUT_LANG
# DE: Steuert die Sprache aller Konsolenausgaben, Logmeldungen, mail.txt,
#     mail.html und summary.json. Erlaubte Werte sind nur de oder en.
# EN: Controls the language of all console output, log messages, mail.txt,
#     mail.html and summary.json. Allowed values are only de or en.
OUTPUT_LANG=de

# ============================================================
# Projektpfade / Project paths
# ============================================================

# BASE_DIR
# DE: Basisordner des gesamten SecurityWatch-Projekts auf der NAS.
#     Alle anderen Standardpfade bauen logisch darauf auf.
# EN: Base directory of the full SecurityWatch project on the NAS.
#     All other default paths are logically derived from it.
BASE_DIR=/volume2/docker/securitywatch

# REPORT_DIR
# DE: Hier legt SecurityWatch pro Lauf einen Zeitstempel-Ordner an.
#     Darin liegen u. a. scan.log, summary.json, mail.txt und mail.html.
# EN: SecurityWatch creates one timestamped folder here per run.
#     It contains scan.log, summary.json, mail.txt and mail.html, among others.
REPORT_DIR=/volume2/docker/securitywatch/reports

# CACHE_DIR
# DE: Persistenter Trivy-Cache. Dadurch müssen Datenbank und Metadaten
#     nicht bei jedem Lauf vollständig neu geladen werden.
# EN: Persistent Trivy cache. This avoids downloading the full database
#     and metadata again on every run.
CACHE_DIR=/volume2/docker/securitywatch/trivy-cache

# STATE_DIR
# DE: Ordner für Zustandsdaten des Pakets. Der Ordner wird automatisch erstellt.
# EN: Directory for package state data. The folder is created automatically.
STATE_DIR=/volume2/docker/securitywatch/state

# ============================================================
# Trivy / Scanverhalten / Trivy / scan behavior
# ============================================================

# TRIVY_IMAGE
# DE: Docker-Image, das für den Trivy-Scan verwendet wird.
#     Für automatische Updates kann latest verwendet werden.
#     Für reproduzierbare feste Ergebnisse kann eine konkrete Version gepinnt werden.
# EN: Docker image used for the Trivy scan.
#     Use latest for automatic updates.
#     Pin a specific version if you need fully reproducible fixed results.
TRIVY_IMAGE=ghcr.io/aquasecurity/trivy:latest

# TRIVY_AUTO_PULL_IMAGE
# DE: 1 = Das konfigurierte Trivy-Docker-Image vor jedem Scan automatisch pullen.
#     Docker lädt dabei nur neue Layer herunter, wenn wirklich ein neueres Image
#     vorhanden ist. Ist das Image aktuell, wird nichts neu heruntergeladen.
#     0 = Trivy-Image nicht automatisch aktualisieren.
# EN: 1 = Automatically pull the configured Trivy Docker image before each scan.
#     Docker only downloads new layers when a newer image actually exists.
#     If the image is already current, nothing is downloaded again.
#     0 = Do not automatically update the Trivy image.
TRIVY_AUTO_PULL_IMAGE=1

# TRIVY_SKIP_VERSION_CHECK
# DE: 1 = Trivy-Versionsprüfung unterdrücken.
#     0 = Trivy darf anzeigen, wenn eine neuere Version verfügbar ist.
#     Bei TRIVY_AUTO_PULL_IMAGE=1 kann dieser Wert normalerweise auf 0 bleiben.
# EN: 1 = Suppress Trivy version checks.
#     0 = Allow Trivy to show when a newer version is available.
#     With TRIVY_AUTO_PULL_IMAGE=1 this can usually stay at 0.
TRIVY_SKIP_VERSION_CHECK=0

# TRIVY_SEVERITIES
# DE: Schweregrade, die im Bericht berücksichtigt werden sollen.
#     Typisch sind HIGH,CRITICAL.
# EN: Severities that should be included in the report.
#     Typical values are HIGH,CRITICAL.
TRIVY_SEVERITIES=HIGH,CRITICAL

# TRIVY_TIMEOUT
# DE: Maximale Laufzeit pro Trivy-Aufruf, z. B. 15m, 30m oder 60m.
#     Bei vielen Images oder langsamer Internetverbindung ggf. erhöhen.
# EN: Maximum runtime per Trivy invocation, e.g. 15m, 30m or 60m.
#     Increase it if you scan many images or have a slow internet connection.
TRIVY_TIMEOUT=60m

# TRIVY_IGNORE_UNFIXED
# DE: 1 = blendet Schwachstellen ohne verfügbaren Fix aus.
#     0 = zeigt auch Funde ohne bekannte Behebung an.
# EN: 1 = hides vulnerabilities without an available fix.
#     0 = also includes findings without a known fix.
TRIVY_IGNORE_UNFIXED=0

# TRIVY_SCAN_FILESYSTEM
# DE: 1 = Host-Dateisystem unter /host scannen.
#     0 = Host-Dateisystem-Scan komplett deaktivieren.
# EN: 1 = scan the host filesystem mounted at /host.
#     0 = disable the host filesystem scan completely.
TRIVY_SCAN_FILESYSTEM=1

# TRIVY_SCAN_IMAGES
# DE: 1 = Docker-Images der aktuell laufenden Container scannen.
#     0 = Image-Scans komplett deaktivieren.
# EN: 1 = scan Docker images of the currently running containers.
#     0 = disable image scans completely.
TRIVY_SCAN_IMAGES=1

# TRIVY_SKIP_DIRS
# DE: Kommagetrennte Liste von Host-Pfaden, die Trivy beim Rootfs-Scan
#     überspringen soll. Nur bewusst ändern, da zu viele Ausschlüsse zu
#     blinden Flecken im Bericht führen können.
# EN: Comma-separated list of host paths that Trivy should skip during the
#     rootfs scan. Change this only deliberately, because too many exclusions
#     can create blind spots in the report.
TRIVY_SKIP_DIRS=/host/proc,/host/sys,/host/dev,/host/run,/host/tmp,/host/mnt,/host/media,/host/volume1,/host/volume2,/host/volume3

# ============================================================
# Docker-Bereinigung vor dem Scan / Docker cleanup before scan
# ============================================================

# DOCKER_CLEANUP_BEFORE_SCAN
# DE: 1 = Vor dem SecurityWatch-Scan eine Docker-Bereinigung ausführen.
#     Dadurch werden alte, nicht mehr verwendete Images entfernt, bevor Trivy
#     die aktuell laufenden Container-Images scannt.
#     0 = Keine Docker-Bereinigung vor dem Scan ausführen.
# EN: 1 = Run Docker cleanup before the SecurityWatch scan.
#     This removes old unused images before Trivy scans the images of the
#     currently running containers.
#     0 = Do not run Docker cleanup before the scan.
DOCKER_CLEANUP_BEFORE_SCAN=1

# DOCKER_PRUNE_UNUSED_IMAGES
# DE: 1 = Alle Docker-Images löschen, die von keinem Container mehr verwendet werden.
#     Laufende oder gestoppte Container und Volumes werden dabei nicht gelöscht.
#     Das aktuell verwendete Trivy-Image wird geschützt, alte unbenutzte Trivy-Images
#     dürfen aber entfernt werden.
#     0 = Nur dangling Images löschen.
# EN: 1 = Remove all Docker images that are no longer used by any container.
#     Running or stopped containers and volumes are not deleted.
#     The currently used Trivy image is protected, but old unused Trivy images
#     may be removed.
#     0 = Remove dangling images only.
DOCKER_PRUNE_UNUSED_IMAGES=1

# DOCKER_PRUNE_BUILD_CACHE
# DE: 1 = Ungenutzten Docker-Build-Cache löschen.
#     Das kann nach mehreren lokalen Image-Builds viel Speicher freigeben.
#     0 = Docker-Build-Cache behalten.
# EN: 1 = Remove unused Docker build cache.
#     This can free storage after several local image builds.
#     0 = Keep Docker build cache.
DOCKER_PRUNE_BUILD_CACHE=1

# ============================================================
# Lokale Images / Local images
# ============================================================

# LOCAL_IMAGE_REPORT_ENABLED
# DE: 1 = Zusatzreport für lokale bzw. selbst gebaute Images erzeugen.
#     Der Report listet automatisch erkannte lokale Build-Images und behebbare
#     Paket-Funde mit installierter Version und Fix-Version auf.
#     0 = Zusatzreport deaktivieren.
# EN: 1 = Create an additional report for local / self-built images.
#     The report lists automatically detected local build images and fixable
#     package findings with installed and fixed versions.
#     0 = Disable the additional report.
LOCAL_IMAGE_REPORT_ENABLED=1

# LOCAL_IMAGE_INCLUDE_PATTERNS
# DE: Optionale zusätzliche Muster für Images, die immer als lokale Images
#     behandelt werden sollen. Mehrere Muster mit Komma trennen.
#     Normalerweise leer lassen, weil SecurityWatch Compose-Build-Images
#     automatisch generisch erkennt.
#     Beispiel: myproject-*,*:local
# EN: Optional additional patterns for images that should always be treated
#     as local images. Separate multiple patterns with commas.
#     Usually leave this empty because SecurityWatch detects Compose build
#     images generically.
#     Example: myproject-*,*:local
LOCAL_IMAGE_INCLUDE_PATTERNS=

# LOCAL_IMAGE_EXCLUDE_PATTERNS
# DE: Optionale Muster für Images, die trotz automatischer Erkennung nicht als
#     lokale Images behandelt werden sollen. Mehrere Muster mit Komma trennen.
#     Beispiel: ghcr.io/*,linuxserver/*
# EN: Optional patterns for images that should not be treated as local images
#     even if automatic detection would include them. Separate multiple patterns
#     with commas.
#     Example: ghcr.io/*,linuxserver/*
LOCAL_IMAGE_EXCLUDE_PATTERNS=

# ============================================================
# Report-Aufbewahrung / Report retention
# ============================================================

# REPORT_CLEANUP_ENABLED
# DE: 1 = Alte Report-Ordner automatisch aufräumen.
#     0 = Keine alten Reports automatisch löschen.
# EN: 1 = Automatically clean up old report folders.
#     0 = Do not automatically delete old reports.
REPORT_CLEANUP_ENABLED=1

# REPORT_RETENTION_DAYS
# DE: Report-Ordner löschen, die älter als diese Anzahl Tage sind.
#     0 = nichts anhand des Alters löschen.
# EN: Delete report folders older than this number of days.
#     0 = do not delete anything based on age.
REPORT_RETENTION_DAYS=30

# REPORT_KEEP_LAST
# DE: Mindestens diese Anzahl der neuesten Report-Ordner immer behalten,
#     auch wenn sie älter als REPORT_RETENTION_DAYS sind.
# EN: Always keep at least this number of newest report folders,
#     even if they are older than REPORT_RETENTION_DAYS.
REPORT_KEEP_LAST=10


# ============================================================
# Mail / SMTP
# ============================================================

# SMTP_SERVER
# DE: Hostname oder IP-Adresse des SMTP-Servers für den Versand.
# EN: Hostname or IP address of the SMTP server used for sending.
SMTP_SERVER=

# SMTP_PORT
# DE: SMTP-Port. Häufig 587 für STARTTLS oder 25 in internen Netzen.
#     Dieses Skript verwendet STARTTLS, wenn SMTP_STARTTLS=1 gesetzt ist.
# EN: SMTP port. Common values are 587 for STARTTLS or 25 on internal networks.
#     This script uses STARTTLS when SMTP_STARTTLS=1 is set.
SMTP_PORT=587

# SMTP_STARTTLS
# DE: 1 = STARTTLS nach dem Verbindungsaufbau verwenden.
#     0 = unverschlüsselt bzw. ohne STARTTLS verbinden.
# EN: 1 = use STARTTLS after connecting.
#     0 = connect without STARTTLS.
SMTP_STARTTLS=1

# SMTP_FROM
# DE: Absenderadresse der erzeugten SecurityWatch-Mails.
# EN: Sender address used for generated SecurityWatch emails.
SMTP_FROM=

# SMTP_TO
# DE: Empfängeradresse der SecurityWatch-Mails.
#     Mehrere Empfänger können je nach Mailserver komma-getrennt angegeben werden.
# EN: Recipient address for SecurityWatch emails.
#     Depending on the mail server, multiple recipients can be provided comma-separated.
SMTP_TO=

# SMTP_USER
# DE: SMTP-Benutzername für die Authentifizierung.
#     Leer lassen, wenn dein Server keine Anmeldung verlangt.
# EN: SMTP username for authentication.
#     Leave empty if your server does not require authentication.
SMTP_USER=

# SMTP_PASS
# DE: SMTP-Passwort im Klartext. Aus Sicherheitsgründen möglichst leer lassen
#     und stattdessen SMTP_PASS_FILE verwenden. 
# EN: SMTP password in plain text. For security reasons, preferably leave this
#     empty and use SMTP_PASS_FILE instead. 
SMTP_PASS=

# SMTP_PASS_FILE
# DE: Optionaler Pfad zu einer Datei, die ausschließlich das SMTP-Passwort enthält.
#     Wenn gesetzt, wird dieses Passwort bevorzugt verwendet.
# EN: Optional path to a file that contains only the SMTP password.
#     If set, this password is used preferentially.
SMTP_PASS_FILE=

# ============================================================
# Versandverhalten / Mail sending behavior
# ============================================================

# MAIL_ONLY_ON_FINDINGS
# DE: 1 = nur dann eine Mail senden, wenn HIGH- oder CRITICAL-Treffer vorhanden sind.
#     0 = Mailversand grundsätzlich zulassen, abhängig von MAIL_SEND_OK.
# EN: 1 = send an email only when HIGH or CRITICAL findings exist.
#     0 = generally allow email sending, depending on MAIL_SEND_OK.
MAIL_ONLY_ON_FINDINGS=1

# MAIL_SEND_OK
# DE: 1 = auch dann eine Mail senden, wenn keine HIGH- oder CRITICAL-Treffer
#     vorhanden sind. Praktisch für Funktionstests.
#     0 = bei einem sauberen Lauf keine OK-Mail senden.
# EN: 1 = also send an email when no HIGH or CRITICAL findings exist.
#     Useful for functional testing.
#     0 = do not send an OK email for a clean run.
MAIL_SEND_OK=0

# MAIL_SUBJECT_PREFIX
# DE: Fester Präfix am Anfang des Mail-Betreffs.
#     Dahinter ergänzt das Skript automatisch den Ergebnistext.
# EN: Fixed prefix at the beginning of the email subject.
#     The script appends the result text automatically afterwards.
MAIL_SUBJECT_PREFIX='[UGREEN SecurityWatch]'
